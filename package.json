{
  "name": "donumate",
  "version": "0.0.7",
  "description": "Standalone CLI for launching Donut Camoufox profiles and automating them over WebDriver BiDi.",
  "type": "module",
  "bin": {
    "donumate": "./dist/cli.js"
  },
  "pkg": {
    "scripts": [
      "dist/**/*.js"
    ],
    "assets": [
      "scripts/**/*",
      "README.md"
    ],
    "targets": [
      "node22-win-x64",
      "node22-linux-x64",
      "node22-macos-x64",
      "node22-macos-arm64"
    ],
    "outputPath": "release"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "start": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "dotenv": "^16.4.7",
    "esbuild": "^0.28.1",
    "ink": "^5.2.1",
    "react": "^18.3.1",
    "ws": "^8.18.0",
    "xlsx": "^0.18.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "@types/react": "^18.3.31",
    "@types/ws": "^8.5.14",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.15.4"
}
