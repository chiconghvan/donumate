inputs {
  autoValue: input = "123"
  textValue: text = "hello input ui"
  numberValue: number = 42
  filePath: file
  folderPath: folder
  enabled: checkbox = true
  mode: comboBox ["alpha", "beta", "gamma"] = "beta"
}

before run profile {
  log "[before] autoValue=${autoValue}"
  log "[before] textValue=${textValue}"
  log "[before] numberValue=${numberValue}"
  log "[before] filePath=${filePath}"
  log "[before] folderPath=${folderPath}"
  log "[before] enabled=${enabled}"
  log "[before] mode=${mode}"
}

run profile {
  log "[main] all inputs available after profile launch"
  log "auto=${autoValue} text=${textValue} number=${numberValue} file=${filePath} folder=${folderPath} enabled=${enabled} mode=${mode}"
  nav "https://example.com/?mode=${mode}&enabled=${enabled}&value=${autoValue}"
  waitLoad
  info
}

after kill profile {
  log "[after] profile killed"
  log "[after] final mode=${mode} outputFolder=${folderPath}"
}
