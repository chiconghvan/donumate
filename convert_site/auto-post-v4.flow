inputs {
  port: input = "8089"
  profileName: input = ""
  profileProxy: input = ""
  postName: input = ""
  isChange: comboBox ["Yes", "No"] = "No"
  avatarFolder: folder = ""
}

before() {
  httpRequest('http://127.0.0.1:${port}/v1/events/profile-init', POST, '{"Content-Type":"application/json"}', '{ "action_name": "post_status", "profileName": "${profileName}", "proxy": "${profileProxy}" }')
}

running() {
  avatarArr = getFiles('${avatarFolder}')
  countAvatar = arrayLength(avatarArr)
  countAvatar = countAvatar - 1
  timeRun = js("(() => { const now = new Date(); const day = String(now.getDate()).padStart(2, '0'); const month = String(now.getMonth() + 1).padStart(2, '0'); const hour = String(now.getHours()).padStart(2, '0'); const minute = String(now.getMinutes()).padStart(2, '0'); return '[' + day + '/' + month + ' ' + hour + ':' + minute + ']'; })()")
  httpRequest('http://127.0.0.1:${port}/v1/events/action-status', POST, '{"Content-Type":"application/json"}', '{ "action_name": "post_status", "profileName": "${profileName}", "postId": "${postName}", "status": "pending", "message": "Go to Threads" }')
  nav('https://www.threads.com/', rDelay(1000,2000))
  currentUrl = getUrl()
  httpRequest('http://127.0.0.1:${port}/v1/events/action-status', POST, '{"Content-Type":"application/json"}', '{ "action_name": "post_status", "profileName": "${profileName}", "postId": "${postName}", "status": "pending", "message": "Checking Suspended" }')
  if contains(currentUrl, 'suspended') {
    httpRequest('http://127.0.0.1:${port}/v1/events/sus-status', POST, '{"Content-Type":"application/json"}', '{ "action_name": "post_status", "profileName": "${profileName}", "message": "Sus Threads" }')
    exit('GPM stop/exit')
  }
  for loopIndex = 0; loopIndex < 3; loopIndex = loopIndex + 1 {
    waitElement('(//div[@data-pressable-container="true"]/ancestor::div[3])[2]', 30000, rDelay(4000,6000))
    if hasElement('//*[@aria-label="Instagram"]') {
      httpRequest('http://127.0.0.1:${port}/v1/events/sus-status', POST, '{"Content-Type":"application/json"}', '{ "action_name": "post_status", "profileName": "${profileName}", "message": "Sus Instagram" }')
      exit('GPM stop/exit')
    }
    if !hasElement('(//div[@data-pressable-container="true"]/ancestor::div[3])[2]') {
      reloadNav()
    }
    else {
      exitLoop
    }
  }
  if !hasElement('(//div[@data-pressable-container="true"]/ancestor::div[3])[2]') {
    httpRequest('http://127.0.0.1:${port}/v1/events/sus-status', POST, '{"Content-Type":"application/json"}', '{ "action_name": "post_status", "profileName": "${profileName}", "message": "Sus Instagram" }')
    fileAppendText('E:\OneDrive\0. Threads\Log\DieAcc.txt', '${timeRun} ${profileName} - Sus Account')
    exit('GPM stop/exit')
  }
  if hasElement('//div[@role="dialog"]') {
    sendKey('Escape')
  }
  httpRequest('http://127.0.0.1:${port}/v1/events/action-status', POST, '{"Content-Type":"application/json"}', '{ "action_name": "post_status", "profileName": "${profileName}", "postId": "${postName}", "status": "pending", "message": "Press Post button" }')
  avatarLink = getElementAttribute('(//div[text()="Đăng" or text()="Post"]/ancestor::div[@role="button"][1])/parent::*/parent::*/a//img', 'src')
  if contains(avatarLink, '5OTfmveiK1K.jpg') {
    if isChange == 'Yes' {
      log('FLOW_GAP skipped GPM type 58 click: missing XPath')
      avatarIndex = randomNum(0, countAvatar)
      log('FLOW_GAP skipped GPM type 58 click: missing XPath')
      waitElement('(//div[text()="Đăng" or text()="Post"]/ancestor::div[@role="button"][1])/parent::*/parent::*/a', 10000)
      if !hasElement('(//div[text()="Đăng" or text()="Post"]/ancestor::div[@role="button"][1])/parent::*/parent::*/a') {
        for loopIndex = 1; loopIndex < 5; loopIndex = loopIndex + 1 {
          reloadNav()
          waitElement('(//div[text()="Đăng" or text()="Post"]/ancestor::div[@role="button"][1])/parent::*/parent::*/a', 5000, rDelay(2000,4000))
          if hasElement('(//div[text()="Đăng" or text()="Post"]/ancestor::div[@role="button"][1])/parent::*/parent::*/a') {
            exitLoop
          }
          currentUrl = getUrl()
          if contains(currentUrl, 'suspended') {
            httpRequest('http://127.0.0.1:${port}/v1/events/sus-status', POST, '{"Content-Type":"application/json"}', '{ "action_name": "post_status", "profileName": "${profileName}", "message": "Sus Threads" }')
            exitLoop
          }
        }
      }
      else {
        click('(//div[text()="Đăng" or text()="Post"]/ancestor::div[@role="button"][1])/parent::*/parent::*/a')
        waitElement('//div[text()="Edit profile" or text()="Chỉnh sửa trang cá nhân"]/ancestor::div[@role="button"]', 20000, rDelay(1000,3000))
        click('//div[text()="Edit profile" or text()="Chỉnh sửa trang cá nhân"]/ancestor::div[@role="button"]')
        waitElement('//input[@type="file"]', 20000, rDelay(1500,3000))
        click('//input[@type="file"]/parent::*//ancestor::div[@role="button"]', rDelay(1000,3000))
        fileUpload('${avatarArr[avatarIndex]}', '//input[@type="file"]', rDelay(2000,4000))
        waitElement('//input[@type="file"]/parent::*//ancestor::div[@role="button"]//img', 20000, rDelay(500,1000))
        click('//div[@aria-hidden="false"]//div[text()="Xong" or text()="Done"]/ancestor::div[@role="button"][1]', rDelay(2000,4000))
        delay(3000, 5000)
      }
      nav('https://www.threads.com/', rDelay(1000,2000))
    }
  }
  click('(//div[text()="Đăng" or text()="Post"]/ancestor::div[@role="button"][1])', rDelay(1000,3000))
  waitElement('//div[@role="textbox"]/.//p', 20000, rDelay(2000,3000))
  delay(0, 3000)
  httpRequest('http://127.0.0.1:${port}/v1/events/action-status', POST, '{"Content-Type":"application/json"}', '{ "action_name": "post_status", "profileName": "${profileName}", "postId": "${postName}", "status": "pending", "message": "Find Content" }')
  searchContent = 'pending'
  while searchContent == 'pending' {
    respone = httpRequest('http://127.0.0.1:${port}/v1/content/next-post?profile=${profileName}', 'GET', '{}')
    postName = readJson(respone, 'post.id')
    content = readJson(respone, 'post.content')
    comment = readJson(respone, 'post.comment')
    path = readJson(respone, 'post.media_path')
    mediaFolder = path
    isMediaFolder = folderExist('${mediaFolder}')
    if isMediaFolder == true {
      isNewContentMedia = folderExist('${mediaFolder}\content')
      if isNewContentMedia == true {
        mediaFileList = getFiles('${mediaFolder}\content')
        countMediaFile = arrayLength(mediaFileList)
        if countMediaFile>0 {
          contentLength = js("(() => { const str = String.raw`${content}`; return str.length; })()")
          if contentLength<500 {
            searchContent = 'done'
          }
          else {
            httpRequest('http://127.0.0.1:${port}/v1/content/posts/mark-bad', POST, '{"Content-Type":"application/json"}', '{ "id": "${postName}" }')
          }
        }
        else {
          httpRequest('http://127.0.0.1:${port}/v1/content/posts/mark-bad', POST, '{"Content-Type":"application/json"}', '{ "id": "${postName}" }')
        }
      }
      else {
        mediaFileList = getFiles('${mediaFolder}')
        countMediaFile = arrayLength(mediaFileList)
        if countMediaFile  ==  0 {
          httpRequest('http://127.0.0.1:${port}/v1/content/posts/mark-bad', POST, '{"Content-Type":"application/json"}', '{ "id": "${postName}" }')
        }
        else {
          contentLength = js("(() => { const str = String.raw`${content}`; return str.length; })()")
          if contentLength<500 {
            searchContent = 'done'
          }
          else {
            httpRequest('http://127.0.0.1:${port}/v1/content/posts/mark-bad', POST, '{"Content-Type":"application/json"}', '{ "id": "${postName}" }')
          }
        }
      }
    }
    else {
      httpRequest('http://127.0.0.1:${port}/v1/content/posts/mark-bad', POST, '{"Content-Type":"application/json"}', '{ "id": "${postName}" }')
    }
  }
  httpRequest('http://127.0.0.1:${port}/v1/events/action-status', POST, '{"Content-Type":"application/json"}', '{ "action_name": "post_status", "profileName": "${profileName}", "postId": "${postName}", "status": "pending", "message": "Start Posting" }')
  isOldContent = folderExist('${mediaFolder}\content')
  comment = js("(() => { let comment = `${comment}`; let count = 0; comment = comment.replace(/s\.shopee\.vn\/\S+/g, (match) => { count++; return count <= 5 ? match : ''; }); return comment; })()")
  if isOldContent  == false {
    mediaFileList = getFiles('${path}')
    countMediaFile = arrayLength(mediaFileList)
    if countMediaFile  ==  0 {
      httpRequest('http://127.0.0.1:${port}/v1/events/action-status', POST, '{"Content-Type":"application/json"}', '{ "action_name": "post_status", "profileName": "${profileName}", "postId": "${postName}", "status": "failed", "message": "No Media detected" }')
      exit('GPM stop/exit')
    }
    httpRequest('http://127.0.0.1:${port}/v1/events/action-status', POST, '{"Content-Type":"application/json"}', '{ "action_name": "post_status", "profileName": "${profileName}", "postId": "${postName}", "status": "pending", "message": "Input Content" }')
    pasteText('//div[@role="textbox"]/.//p', '${content}', rDelay(1000,1500))
    httpRequest('http://127.0.0.1:${port}/v1/events/action-status', POST, '{"Content-Type":"application/json"}', '{ "action_name": "post_status", "profileName": "${profileName}", "postId": "${postName}", "status": "pending", "message": "Upload Media" }')
    for loopIndex = 0; loopIndex < countMediaFile; loopIndex = loopIndex + 1 {
      fileUpload('${mediaFileList[loopIndex]}', '//input[@type="file"]', rDelay(3000,4000))
    }
    countMediaFile = countMediaFile - 1
    lastMedia = mediaFileList[countMediaFile]
    httpRequest('http://127.0.0.1:${port}/v1/events/action-status', POST, '{"Content-Type":"application/json"}', '{ "action_name": "post_status", "profileName": "${profileName}", "postId": "${postName}", "status": "pending", "message": "Add Comment" }')
    click('//span[text()="Thêm vào thread" or text()="Add to thread"]', rDelay(1000,2000))
    waitElement('(//div[@role="textbox"]/.//p)[2]', 10000)
    isVideo = js("(() => { const str = ""${lastMedia}""; let videoExt = [ '.mp4', '.mov', '.avi', '.mkv', '.wmv', '.flv', '.webm', '.mpeg', '.mpg', '.m4v', '.3gp', '.ts' ]; let ext = str.split(/[/\\]/).pop().split('.').pop().toLowerCase(); let isVideo = videoExt.includes('.' + ext); return isVideo; })()")
    if isVideo  == false {
      fileUpload('${lastMedia}', '//input[@type="file"]', rDelay(3000,4000))
      pasteText('(//div[@role="textbox"]/.//p)[2]', '${comment}', rDelay(1000,1500))
    }
    else {
      pasteText('(//div[@role="textbox"]/.//p)[2]', '${comment}', rDelay(1000,1500))
      waitElement('(((//div[@role="textbox"]/p)[2]/ancestor::div[3])//*[contains(@style,"--x-height: 12px")])[2]/ancestor::div[@role="button"]', 10000)
      if hasElement('(((//div[@role="textbox"]/p)[2]/ancestor::div[3])//*[contains(@style,"--x-height: 12px")])[2]/ancestor::div[@role="button"]') {
        click('(((//div[@role="textbox"]/p)[2]/ancestor::div[3])//*[contains(@style,"--x-height: 12px")])[2]/ancestor::div[@role="button"]', rDelay(500,1000))
      }
    }
    delay(4000, 8000)
    httpRequest('http://127.0.0.1:${port}/v1/events/action-status', POST, '{"Content-Type":"application/json"}', '{ "action_name": "post_status", "profileName": "${profileName}", "postId": "${postName}", "status": "pending", "message": "Posting" }')
    click('//div[@role="dialog" or @role="menu"]//div[text()="Đăng" or text()="Post"]')
    waitElement('//div[@data-visualcompletion="ignore"]//span[text()="Xem" or text()="View"]', 90000)
  }
  else {
    mediaFileList = getFiles('${path}\content')
    countMediaFile = arrayLength(mediaFileList)
    httpRequest('http://127.0.0.1:${port}/v1/events/action-status', POST, '{"Content-Type":"application/json"}', '{ "action_name": "post_status", "profileName": "${profileName}", "postId": "${postName}", "status": "pending", "message": "Input Content" }')
    pasteText('//div[@role="textbox"]/.//p', '${content}', rDelay(1000,1500))
    if !hasElement('//span[text()="Thêm vào thread" or text()="Add to thread"]') {
      httpRequest('http://127.0.0.1:${port}/v1/events/action-status', POST, '{"Content-Type":"application/json"}', '{ "action_name": "post_status", "profileName": "${profileName}", "postId": "${postName}", "status": "failed", "message": "Post Failed" }')
      httpRequest('http://127.0.0.1:${port}/v1/content/posts/mark-bad', POST, '{"Content-Type":"application/json"}', '{ "postId": "${postName}" }')
      exit('GPM stop/exit')
    }
    httpRequest('http://127.0.0.1:${port}/v1/events/action-status', POST, '{"Content-Type":"application/json"}', '{ "action_name": "post_status", "profileName": "${profileName}", "postId": "${postName}", "status": "pending", "message": "Upload Media" }')
    for loopIndex = 0; loopIndex < countMediaFile; loopIndex = loopIndex + 1 {
      fileUpload('${mediaFileList[loopIndex]}', '//input[@type="file"]', rDelay(3000,4000))
    }
    countMediaFile = countMediaFile - 1
    lastMedia = mediaFileList[countMediaFile]
    httpRequest('http://127.0.0.1:${port}/v1/events/action-status', POST, '{"Content-Type":"application/json"}', '{ "action_name": "post_status", "profileName": "${profileName}", "postId": "${postName}", "status": "pending", "message": "Add Comment" }')
    click('//span[text()="Thêm vào thread" or text()="Add to thread"]', rDelay(1000,2000))
    waitElement('(//div[@role="textbox"]/.//p)[2]', 10000)
    mediaFileList = getFiles('${path}\comment')
    countMediaFile = arrayLength(mediaFileList)
    isVideo = js("(() => { const str = ""${lastMedia}""; let videoExt = [ '.mp4', '.mov', '.avi', '.mkv', '.wmv', '.flv', '.webm', '.mpeg', '.mpg', '.m4v', '.3gp', '.ts' ]; let ext = str.split(/[/\\]/).pop().split('.').pop().toLowerCase(); let isVideo = videoExt.includes('.' + ext); return isVideo; })()")
    if countMediaFile == 0 {
      if isVideo  == false {
        fileUpload('${lastMedia}', '//input[@type="file"]', rDelay(3000,4000))
        pasteText('(//div[@role="textbox"]/.//p)[2]', '${comment}', rDelay(1000,1500))
      }
      else {
        pasteText('(//div[@role="textbox"]/.//p)[2]', '${comment}', rDelay(1000,1500))
        waitElement('(((//div[@role="textbox"]/p)[2]/ancestor::div[3])//*[contains(@style,"--x-height: 12px")])[2]/ancestor::div[@role="button"]', 10000)
        if hasElement('(((//div[@role="textbox"]/p)[2]/ancestor::div[3])//*[contains(@style,"--x-height: 12px")])[2]/ancestor::div[@role="button"]') {
          click('(((//div[@role="textbox"]/p)[2]/ancestor::div[3])//*[contains(@style,"--x-height: 12px")])[2]/ancestor::div[@role="button"]', rDelay(500,1000))
        }
      }
    }
    else {
      for loopIndex = 0; loopIndex < countMediaFile; loopIndex = loopIndex + 1 {
        fileUpload('${mediaFileList[loopIndex]}', '//input[@type="file"]', rDelay(3000,4000))
      }
      pasteText('(//div[@role="textbox"]/.//p)[2]', '${comment}', rDelay(1000,1500))
    }
    delay(4000, 8000)
    httpRequest('http://127.0.0.1:${port}/v1/events/action-status', POST, '{"Content-Type":"application/json"}', '{ "action_name": "post_status", "profileName": "${profileName}", "postId": "${postName}", "status": "pending", "message": "Posting" }')
    click('//div[@role="dialog" or @role="menu"]//div[text()="Đăng" or text()="Post"]/ancestor::div[@role="button"]')
    waitElement('//div[@data-visualcompletion="ignore"]//span[text()="Xem" or text()="View"]', 90000)
  }
  if hasElement('//div[@data-visualcompletion="ignore"]//*[text()="Đã đăng" or text()="Posted"]') {
    httpRequest('http://127.0.0.1:${port}/v1/events/action-status', POST, '{"Content-Type":"application/json"}', '{ "action_name": "post_status", "profileName": "${profileName}", "postId": "${postName}", "status": "done", "message": "Posted" }')
  }
  else if hasElement('//div[@data-visualcompletion="ignore"]//*[text()="Post failed to upload" or text()="Chưa tải được bài viết lên"]') {
    postStatus = false
    httpRequest('http://127.0.0.1:${port}/v1/events/action-status', POST, '{"Content-Type":"application/json"}', '{ "action_name": "post_status", "profileName": "${profileName}", "postId": "${postName}", "status": "pending", "message": "Retry Posting" }')
    for loopIndex = 1; loopIndex < 6; loopIndex = loopIndex + 1 {
      waitElement('//div[@data-visualcompletion="ignore"]//span[text()="Xem" or text()="View"]', 90000)
      click('//div[@data-visualcompletion="ignore"]//span[text()="Xem" or text()="View"]', rDelay(1000,2000))
      waitElement('//div[@role="dialog"]//div[text()="Đăng" or text()="Post"]', 15000)
      httpRequest('http://127.0.0.1:${port}/v1/events/action-status', POST, '{"Content-Type":"application/json"}', '{ "action_name": "post_status", "profileName": "${profileName}", "postId": "${postName}", "status": "pending", "message": "Retry ${loopIndex}/5" }')
      click('//div[@role="dialog" or @role="menu"]//div[text()="Đăng" or text()="Post"]', rDelay(1000,2000))
      waitElement('//div[@data-visualcompletion="ignore"]//span[text()="Xem" or text()="View"]', 90000)
      if hasElement('//div[@data-visualcompletion="ignore"]//*[text()="Đã đăng" or text()="Posted"]') {
        httpRequest('http://127.0.0.1:${port}/v1/events/action-status', POST, '{"Content-Type":"application/json"}', '{ "action_name": "post_status", "profileName": "${profileName}", "postId": "${postName}", "status": "done", "message": "Posted" }')
        postStatus = true
        exitLoop
      }
    }
    if postStatus == false {
      httpRequest('http://127.0.0.1:${port}/v1/events/action-status', POST, '{"Content-Type":"application/json"}', '{ "action_name": "post_status", "profileName": "${profileName}", "postId": "${postName}", "status": "failed", "message": "Post Failed" }')
    }
  }
  else {
    httpRequest('http://127.0.0.1:${port}/v1/events/action-status', POST, '{"Content-Type":"application/json"}', '{ "action_name": "post_status", "profileName": "${profileName}", "postId": "${postName}", "status": "failed", "message": "Post Failed" }')
  }
  delay(2000, 3000)
}

after() {
}
