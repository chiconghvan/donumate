inputs {
  startUrl: input = "https://9remote.cc/"
  delayMinMs: number = 2000
  delayMaxMs: number = 3000
  notesFile: file
  outputDir: folder
  dryRun: checkbox = false
  mode: comboBox ["fast", "safe", "debug"] = "safe"
}

before() {
  log("Preparing flow mode=${mode} dryRun=${dryRun}")
  log("Notes: ${notesFile}")
  log("Output: ${outputDir}")
}

running() {
  nav("https://example.com/?mode=${mode}&enabled=${enabled}&value=${autoValue}")
  waitLoad()
  delay("${delayMinMs}", "${delayMaxMs}")
  info()

  if hasElement("//h1")
    log("Page has h1")
  else if 1 + 1 == 3
    log("Impossible branch")
  else
    log("Page has no h1")

  for i = 0; i < 2; i = i + 1
    log("for loopIndex=${loopIndex} i=${i}")

  set n = 0
  while n < 2
    log("while loopIndex=${loopIndex} n=${n}")
    set n = n + 1
}

after() {
  log("Profile killed after flow run.")
}
